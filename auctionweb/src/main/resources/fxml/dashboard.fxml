<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:id="mainContainer" prefHeight="600.0" prefWidth="800.0" 
            xmlns="http://javafx.com/javafx/8" 
            xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="frontend.dashboard.DashboardController">
    
    <left>
        <VBox spacing="10" style="-fx-background-color: #2c3e50; -fx-padding: 15;">
            <Label text="MENU" textFill="WHITE" style="-fx-font-weight: bold;"/>
            <Button fx:id="btnHome" text="Trang chủ" onAction="#onMenuHomeClick" maxWidth="Infinity"/>
            <Button fx:id="btnSignup" text="Quản lý" onAction="#onMenuSignupClick" maxWidth="Infinity"/>
            <Button text="Đăng xuất" onAction="#handleLogout" maxWidth="Infinity"/>
        </VBox>
    </left>

    <top>
        <HBox alignment="CENTER_RIGHT" spacing="20" style="-fx-background-color: #ecf0f1; -fx-padding: 10;">
            <Label fx:id="lblUsername" text="Người dùng: Admin" />
            <Label fx:id="lblBalance" text="Số dư: 1,000,000 VNĐ" />
        </HBox>
    </top>

    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: #ffffff;">
            </StackPane>
    </center>
</BorderPane>