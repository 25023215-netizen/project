<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="frontend.bidding.BiddingController"
      style="-fx-background-color: transparent;">
    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>

    <!-- Header -->
    <Label text="💰 ĐẶT GIÁ ĐẤU" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>

    <HBox spacing="25">
        <!-- Left: Form đặt giá -->
        <VBox spacing="18" prefWidth="400"
              style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 30; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 4);">

            <Label text="Thông tin đặt giá" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #334155;"/>
            <Separator/>

            <VBox spacing="6">
                <Label text="Mã phiên đấu giá" style="-fx-font-weight: 600; -fx-text-fill: #475569; -fx-font-size: 14px;"/>
                <TextField fx:id="txtAuctionId" promptText="Nhập mã phiên đấu giá (VD: 1001)"
                           style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #e2e8f0; -fx-padding: 12 16; -fx-font-size: 14px;"/>
            </VBox>

            <VBox spacing="6">
                <Label text="Số tiền đặt giá (VNĐ)" style="-fx-font-weight: 600; -fx-text-fill: #475569; -fx-font-size: 14px;"/>
                <TextField fx:id="txtAmount" promptText="Nhập số tiền (VD: 5000000)"
                           style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #e2e8f0; -fx-padding: 12 16; -fx-font-size: 14px;"/>
            </VBox>

            <Label fx:id="lblStatus" text="" style="-fx-font-size: 14px; -fx-font-weight: 500;"/>

            <HBox spacing="12" alignment="CENTER_RIGHT">
                <Button text="🔄 Xóa" onAction="#handleClear"
                        style="-fx-background-color: #f1f5f9; -fx-text-fill: #475569; -fx-background-radius: 10; -fx-padding: 10 20; -fx-cursor: hand;"/>
                <Button text="💰 Đặt giá ngay" onAction="#handleBid"
                        style="-fx-background-color: linear-gradient(to right, #f59e0b, #ef4444); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 10 24; -fx-font-size: 14px; -fx-cursor: hand;"/>
            </HBox>
        </VBox>

        <!-- Right: Lịch sử đặt giá -->
        <VBox spacing="12" HBox.hgrow="ALWAYS"
              style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 30; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 4);">

            <Label text="📜 Lịch sử đặt giá của bạn" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #334155;"/>
            <Separator/>

            <TableView fx:id="bidHistoryTable" VBox.vgrow="ALWAYS"
                       style="-fx-background-radius: 10;">
                <columns>
                    <TableColumn fx:id="colBidAuctionId" text="Mã phiên" prefWidth="80"/>
                    <TableColumn fx:id="colBidProduct" text="Sản phẩm" prefWidth="180"/>
                    <TableColumn fx:id="colBidAmount" text="Giá đặt" prefWidth="130"/>
                    <TableColumn fx:id="colBidTime" text="Thời gian" prefWidth="150"/>
                    <TableColumn fx:id="colBidStatus" text="Kết quả" prefWidth="100"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>
        </VBox>
    </HBox>
</VBox>