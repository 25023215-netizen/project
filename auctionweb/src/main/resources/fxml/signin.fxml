<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<!-- Root container: StackPane để center nội dung -->
<StackPane fx:controller="frontend.signin.SigninController"
           xmlns:fx="http://javafx.com/fxml"
           stylesheets="@../style/signin.css"
           style="-fx-background-color: linear-gradient(to bottom right, #e3f2fd, #f3e5f5);">
    <!-- Card chính chứa toàn bộ form -->
    <VBox alignment="CENTER" spacing="25" styleClass="form-card">
        <!-- Header section với title -->
        <VBox alignment="CENTER" spacing="10">
            <Label text="Welcome Back" styleClass="title-label"/>
        </VBox>
        <!-- Container chứa các input fields -->
        <VBox spacing="15" styleClass="form-container">
            <!-- Username field với label -->
            <VBox spacing="5">
                <Label text="Username" styleClass="field-label"/>
                <TextField fx:id="userNameField" promptText="Enter your username" styleClass="input-field"/>
            </VBox>
            <!-- Password field với label -->
            <VBox spacing="5">
                <Label text="Password" styleClass="field-label"/>
                <PasswordField fx:id="passwordField" promptText="Enter your password" styleClass="input-field"/>
            </VBox>
            <!-- Label hiển thị lỗi validation -->
            <Label fx:id="statusLabel" styleClass="error-label"/>
        </VBox>
        <!-- Container chứa các buttons -->
        <HBox spacing="15" alignment="CENTER_RIGHT" styleClass="button-container">
            <Button fx:id="signinButton" text="Sign In" onAction="#onSignIn" disable="true" styleClass="primary-button"/>
            <Button text="Cancel" onAction="#onCancel" styleClass="secondary-button"/>
        </HBox>
    </VBox>
</StackPane>
