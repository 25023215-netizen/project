<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="frontend.dashboard.AuctionListController"
      style="-fx-background-color: transparent;">
    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label text="🔨 DANH SÁCH PHIÊN ĐẤU GIÁ" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <TextField fx:id="searchField" promptText="🔍 Tìm kiếm sản phẩm..."
                   prefWidth="250"
                   style="-fx-background-radius: 20; -fx-padding: 10 18; -fx-border-radius: 20; -fx-border-color: #e2e8f0; -fx-background-color: white;"/>
        <ComboBox fx:id="filterStatus" promptText="Trạng thái" prefWidth="160"
                  style="-fx-background-radius: 20; -fx-padding: 4 8;"/>
        <Button text="➕ Tạo mới" onAction="#onCreateAuction"
                style="-fx-background-color: linear-gradient(to right, #667eea, #764ba2); -fx-text-fill: white; -fx-background-radius: 12; -fx-padding: 10 20; -fx-font-weight: bold; -fx-cursor: hand;"/>
    </HBox>

    <!-- Table -->
    <TableView fx:id="auctionTable" VBox.vgrow="ALWAYS"
               style="-fx-background-radius: 12; -fx-background-color: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 4);">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
            <TableColumn fx:id="colName" text="Sản phẩm" prefWidth="200"/>
            <TableColumn fx:id="colStartPrice" text="Giá khởi điểm" prefWidth="140"/>
            <TableColumn fx:id="colCurrentPrice" text="Giá hiện tại" prefWidth="140"/>
            <TableColumn fx:id="colSeller" text="Người bán" prefWidth="130"/>
            <TableColumn fx:id="colStatus" text="Trạng thái" prefWidth="120"/>
            <TableColumn fx:id="colEndTime" text="Thời gian kết thúc" prefWidth="160"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>

    <!-- Footer info -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label fx:id="lblTotal" text="Tổng: 0 phiên đấu giá" style="-fx-text-fill: #64748b; -fx-font-size: 13px;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="🔄 Làm mới" onAction="#onRefresh"
                style="-fx-background-color: #f1f5f9; -fx-text-fill: #475569; -fx-background-radius: 10; -fx-padding: 8 16; -fx-cursor: hand;"/>
    </HBox>
</VBox>
