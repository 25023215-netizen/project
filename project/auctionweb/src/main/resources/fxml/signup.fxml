<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<!-- Root container: StackPane để center nội dung trong cửa sổ -->
<StackPane fx:controller="frontend.signup.SignupController"
           xmlns:fx="http://javafx.com/fxml"
           stylesheets="@../style/signup.css"
           style="-fx-background-color: linear-gradient(to bottom right, #fef3c7, #fde2e2);">
    <!-- Card chính chứa toàn bộ form đăng ký -->
    <VBox alignment="CENTER" spacing="25" styleClass="form-card">
        <!-- Header section: Tiêu đề -->
        <VBox alignment="CENTER" spacing="10">
            <Label text="Create Account" styleClass="title-label"/>
        </VBox>
        <!-- Form container: Chứa các input fields -->
        <VBox spacing="15" styleClass="form-container">
            <!-- Fullname field -->
            <VBox spacing="5">
                <Label text="Full Name" styleClass="field-label"/>
                <TextField fx:id="fullNameField" promptText="Enter your full name" styleClass="input-field"/>
            </VBox>
            <!-- Email field -->
            <VBox spacing="5">
                <Label text="Email" styleClass="field-label"/>
                <TextField fx:id="emailField" promptText="Enter your email" styleClass="input-field"/>
            </VBox>
            <!-- Username field -->
            <VBox spacing="5">
                <Label text="Username" styleClass="field-label"/>
                <TextField fx:id="userNameField" promptText="Choose a username" styleClass="input-field"/>
            </VBox>
            <!-- Password field -->
            <VBox spacing="5">
                <Label text="Password" styleClass="field-label"/>
                <PasswordField fx:id="passwordField" promptText="Create a password" styleClass="input-field"/>
            </VBox>
            <!-- Confirm password field -->
            <VBox spacing="5">
                <Label text="Confirm Password" styleClass="field-label"/>
                <PasswordField fx:id="confirmPasswordField" promptText="Confirm your password" styleClass="input-field"/>
            </VBox>
            <!-- Status label: Hiển thị thông báo lỗi hoặc thành công -->
            <Label fx:id="statusLabel" styleClass="error-label"/>
        </VBox>
        <!-- Button container: Chứa các button hành động -->
        <HBox spacing="15" alignment="CENTER_RIGHT" styleClass="button-container">
            <Button fx:id="signUpButton" text="Sign Up" onAction="#onSignUp" disable="true" styleClass="primary-button"/>
            <Button text="Cancel" onAction="#onCancel" styleClass="secondary-button"/>
        </HBox>
        <!-- Chuyển hướng sang màn hình Đăng nhập -->
        <HBox alignment="CENTER" style="-fx-padding: 0 0 10 0;">
            <Label text="Đã có tài khoản? "/>
            <Hyperlink text="Đăng nhập ngay" onAction="#onGoToSignIn"/>
        </HBox>
    </VBox>
</StackPane>
